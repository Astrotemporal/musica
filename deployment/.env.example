# musica deployment environment
# Copy to .env and fill in your values:  cp .env.example .env

# Timezone
TZ=America/Los_Angeles

# Music library path (host directory)
MUSIC_DIR=./music

# Navidrome admin (set on first launch)
NAVIDROME_ADMIN_USER=admin
NAVIDROME_ADMIN_PASS=changeme

# Last.fm scrobbling (optional)
LASTFM_ENABLED=false
LASTFM_APIKEY=
LASTFM_SECRET=

# Soulseek credentials (required for slskd)
# Create a free account at https://www.slsknet.org/
SOULSEEK_USER=
SOULSEEK_PASS=
